# Root environment example for Clerk + OIDC setup
# Copy to .env and adjust as needed for local development.

# Reverse proxy and public host settings
ACME_EMAIL=admin@sammatthews.nz
APP_BASE_URL=https://app.sammatthews.nz
APP_CORS_ORIGINS=https://app.sammatthews.nz,http://localhost:3000

# Frontend (Vite)
VITE_API_URL=https://api.sammatthews.nz
VITE_CLERK_PUBLISHABLE_KEY=
# Optional: set only if you configured a Clerk JWT template
VITE_CLERK_JWT_TEMPLATE=

# Backend OIDC/JWT validation
# Use your Clerk issuer URL (for example https://clerk.your-domain.com)
OIDC_ISSUER_URLS=https://clerk.example.com
# Use your Clerk JWKS endpoint
OIDC_JWKS_URI=https://clerk.example.com/.well-known/jwks.json
# Optional: enforce audience only if your tokens include aud
OIDC_ACCEPTED_AUDIENCES=
