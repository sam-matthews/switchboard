# Backend Environment Variables
NODE_ENV=development
PORT=3001

# PostgreSQL Database Configuration
DB_HOST=app-db
DB_PORT=5432
DB_NAME=notesapp
DB_USER=appuser
DB_PASSWORD=apppass123

# OIDC/JWT Configuration
OIDC_JWKS_URI=https://clerk.example.com/.well-known/jwks.json
OIDC_ISSUER_URLS=https://clerk.example.com
# Optional: set only if you want strict audience checks
OIDC_ACCEPTED_AUDIENCES=
